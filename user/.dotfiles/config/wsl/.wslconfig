# WSL2 Advanced Configuration
# Applied to $env:USERPROFILE\.wslconfig on Windows host

[wsl2]
memory=4GB
processors=2
localhostForwarding=true

# Nested virtualization for VMs inside WSL
nestedVirtualization=true

# Enable experimental features
experimental.autoMemoryReclaim=true
experimental.sparseVhd=true

# Cap virtual disk growth
defaultVhdSize=256GB
