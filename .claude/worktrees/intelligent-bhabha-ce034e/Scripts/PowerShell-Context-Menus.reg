Windows Registry Editor Version 5.00

; ── .ps1 files → Run as Administrator (Windows Terminal + pwsh 7) ────────────
[HKEY_CLASSES_ROOT\Microsoft.PowerShellScript.1\Shell\RunAsAdmin]
@="Run as &Administrator"
"Icon"="pwsh.exe"
"HasLUAShield"=""

[HKEY_CLASSES_ROOT\Microsoft.PowerShellScript.1\Shell\RunAsAdmin\command]
@="powershell.exe -WindowStyle Hidden -Command \"Start-Process wt -ArgumentList 'new-tab -p PowerShell -- pwsh -ExecutionPolicy Bypass -File \\\"%1\\\"' -Verb RunAs\""

; ── Folders → Open PowerShell 7 here (Windows Terminal, Administrator) ───────
[HKEY_CLASSES_ROOT\Directory\shell\PowerShellAdmin]
@="Open PowerShell 7 here (Administrator)"
"MUIVerb"="Open PowerShell 7 here (Administrator)"
"Icon"="pwsh.exe"
"HasLUAShield"=""

[HKEY_CLASSES_ROOT\Directory\shell\PowerShellAdmin\command]
@="powershell.exe -WindowStyle Hidden -Command \"Start-Process wt -ArgumentList 'new-tab -p PowerShell -d \\\"%V\\\"' -Verb RunAs\""

[HKEY_CLASSES_ROOT\Directory\Background\shell\PowerShellAdmin]
@="Open PowerShell 7 here (Administrator)"
"MUIVerb"="Open PowerShell 7 here (Administrator)"
"Icon"="pwsh.exe"
"HasLUAShield"=""

[HKEY_CLASSES_ROOT\Directory\Background\shell\PowerShellAdmin\command]
@="powershell.exe -WindowStyle Hidden -Command \"Start-Process wt -ArgumentList 'new-tab -p PowerShell -d \\\"%V\\\"' -Verb RunAs\""
