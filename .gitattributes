# GitAttributes - Ven0m0/Win
# Optimized for Windows 10/11 with cross-platform support
# =============================================================================
# Core Settings
# =============================================================================
* text=auto eol=crlf whitespace=blank-at-eol,-blank-at-eof,-space-before-tab,tabwidth=2

# =============================================================================
# PowerShell (Windows Primary)
# =============================================================================
*.{ps1,psm1,psd1} text eol=crlf linguist-language=PowerShell

# =============================================================================
# Windows Scripts
# =============================================================================
*.[cC][mM][dD] text eol=crlf
*.[bB][aA][tT] text eol=crlf
*.ahk text eol=crlf
*.[rR][eE][gG] text eol=crlf

# =============================================================================
# Unix Scripts (WSL/Cross-Platform)
# =============================================================================
*.[sS][hH] text eol=lf diff=bash
*.[bB][aA][sS][hH] text eol=lf diff=bash
bashrc text eol=lf
bash_profile text eol=lf
bash_logout text eol=lf
zshrc text eol=lf
zshenv text eol=lf
zprofile text eol=lf
.profile text eol=lf

# =============================================================================
# Configuration Files
# =============================================================================
*.json text diff=json linguist-language=JSON
*.jsonc text diff=json linguist-language=JSONC
*.yaml text diff=yaml linguist-language=YAML
*.yml text diff=yaml linguist-language=YAML
*.toml text diff=toml linguist-language=TOML
*.xml text diff=xml
*.ini text
*.cfg text
*.conf text
*.config text
*.service text
*.rules text

# Winget configs (YAML-based)
*.winget diff=yaml linguist-language=YAML

# =============================================================================
# Documentation
# =============================================================================
*.md text diff=markdown linguist-detectable linguist-documentation
*.txt text linguist-documentation
*.rst text
*.adoc text

# =============================================================================
# Web Assets
# =============================================================================
*.css text diff=css
*.scss text diff=css
*.sass text diff=css
*.less text diff=css
*.html text diff=html
*.htm text diff=html
*.js text
*.jsx text
*.ts text
*.tsx text
*.vue text
*.svg text

# =============================================================================
# Programming Languages
# =============================================================================
*.py text diff=python linguist-language=Python
*.pyw text linguist-language=Python
*.java text diff=java linguist-language=Java
*.lua text linguist-language=Lua
*.nix text linguist-language=Nix
*.cs text diff=csharp linguist-language=C#
*.fs text diff=tex linguist-language=F#
*.go text diff=golang linguist-language=Go
*.rs text diff=rust linguist-language=Rust
*.rb text diff=ruby linguist-language=Ruby
*.php text diff=php linguist-language=PHP

# =============================================================================
# Build/Project Files
# =============================================================================
*.sln merge=binary
*.csproj merge=binary
*.vbproj merge=binary
*.vcxproj merge=binary
*.vcproj merge=binary
*.dbproj merge=binary
*.fsproj merge=binary
*.lsproj merge=binary
*.wixproj merge=binary
*.modelproj merge=binary
*.sqlproj merge=binary
*.props text
*.targets text

# =============================================================================
# Data Files
# =============================================================================
*.db text
*.sqlite text
*.mdf text
*.ldf text

