*.[bB][mM][pP] binary
*.[iI][cC][oO] binary
*.[sS][vV][gG] text
*.[oO][gG][gG] binary
*.[oO][pP][uU][sS] binary
*.[mM][pP][3] binary
*.[mM][pP][4] binary
*.[aA][vV][iI] binary
*.[mM][kK][vV] binary
*.[fF][lL][aA][cC] binary
*.[wW][aA][vV] binary

# =============================================================================
