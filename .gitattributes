.gitconfig text
.editorconfig text
.dockerignore text
.dockerfile text eol=lf

# Patches
*.[pP][aA][tT][cC][hH] diff=patch
*.[dD][iI][fF] diff=patch

# =============================================================================
# Repository-Specific
# =============================================================================
