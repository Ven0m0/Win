# EditorConfig: https://editorconfig.org
root=true
# =============================================================================
# Default Settings for All Files
# =============================================================================
[*]
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
indent_style = space
indent_size = 2
tab_width = 2
max_line_length = 120

# =============================================================================
# Shell Scripts
# =============================================================================
[**.{sh,bash},bash_*,PKGBUILD,.bash*,.profile]
shell_variant = bash
spaces_around_operators = true
spaces_around_brackets = false
keep_padding = false
space_redirects = false
switch_case_indent = false
function_next_line = false
binary_next_line = true
end_of_line = lf

[*.{bashrc,bash_profile,bash_logout,zshrc,zshenv,zprofile}]
shell_variant = bash
end_of_line = lf

[*.profile]
shell_variant = posix
end_of_line = lf

# Windows Scripts
[**.{bat,cmd,ps1,psm1,psd1}]
indent_style = space
indent_size = 2
end_of_line = crlf

# =============================================================================
# Programming Languages
# =============================================================================
# Python
[**.{py,pyw,pyi}]
indent_size = 4
quote_type = double

# JavaScript/TypeScript
[**.{js,mjs,cjs,jsx}]
quote_type = single

[**.{ts,mts,cts,tsx}]
quote_type = single

# =============================================================================
# Configuration Files
# =============================================================================
# XML
[*.xml]
indent_size = 4

[*.{json,jsonc}]
indent_size = 2
tab_width = 2
indent_style = space

[.kilo/kilo.json]
indent_size = 2
tab_width = 2
indent_style = space

# =============================================================================
# Markup/Documentation
# =============================================================================
[**.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = unset

[**.{patch,diff}]
trim_trailing_whitespace = false
insert_final_newline = false

# =============================================================================
# Build Systems & Package Managers
# =============================================================================
[{poetry.lock,pyproject.toml,setup.py,setup.cfg}]
indent_size = 4

# =============================================================================
# Special Cases
# =============================================================================
# Minified files
[**.min.{js,css}]
insert_final_newline = false

# SVG
[**.svg]
insert_final_newline = false
