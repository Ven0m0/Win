#!/usr/bin/env pwsh
# yadm bootstrap -- thin wrapper that delegates to Scripts/Setup-Dotfiles.ps1
# Usage: yadm bootstrap [-- -WhatIf]

$ErrorActionPreference = 'Stop'

$setupScript = Join-Path $HOME 'Scripts\Setup-Dotfiles.ps1'

if (-not (Test-Path $setupScript)) {
  Write-Error "Setup-Dotfiles.ps1 not found at: $setupScript`nEnsure the Scripts/ directory is present in your HOME."
  exit 1
}

& $setupScript @args
